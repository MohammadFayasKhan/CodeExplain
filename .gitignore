# CodeExplain ➜ Plain-English Code Tutor
# Author ➜ Mohammad Fayas Khan
# Purpose ➜ Ignore generated, temporary, and environment-specific files.

# -----------------------------------------------------------------------------
# Node.js Dependencies
# -----------------------------------------------------------------------------
# Installed packages (can be restored using npm install)
node_modules/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Build & Production Output
# -----------------------------------------------------------------------------
# Generated build folders
build/
dist/
out/

# Static site output
.next/
.nuxt/

# -----------------------------------------------------------------------------
# Cache Files
# -----------------------------------------------------------------------------
# Build caches
.cache/
.parcel-cache/

# Vite cache
.vite/

# Babel cache
babel-loader/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Python virtual environments
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Python Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# -----------------------------------------------------------------------------
# Python Type Checking
# -----------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Python Packaging
# -----------------------------------------------------------------------------
*.egg-info/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
# Never commit secrets
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# IDE Settings
# -----------------------------------------------------------------------------
.vscode/
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Test Reports
# -----------------------------------------------------------------------------
test_reports/
coverage/
reports/

# -----------------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# AI / LLM Cache
# -----------------------------------------------------------------------------
.cache/
hf_cache/
transformers_cache/

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
.vercel/
.netlify/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
Desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Git Merge & Backup Files
# -----------------------------------------------------------------------------
*.orig
*.rej

# -----------------------------------------------------------------------------
# Local Databases
# -----------------------------------------------------------------------------
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Runtime Files
# -----------------------------------------------------------------------------
*.pid
*.seed

# -----------------------------------------------------------------------------
# Compiled Objects
# -----------------------------------------------------------------------------
*.o
*.so
*.dll
*.dylib

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.swp
*.swo